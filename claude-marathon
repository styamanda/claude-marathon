#!/usr/bin/env bash
set -uo pipefail
# Resolve symlinks so the lib is found when invoked via a symlink on PATH.
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR=$(cd -P "$(dirname "$SOURCE")" && pwd)
  SOURCE=$(readlink "$SOURCE")
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR=$(cd -P "$(dirname "$SOURCE")" && pwd)
# shellcheck source=marathon-lib.sh
source "$SCRIPT_DIR/marathon-lib.sh"

RESUME_ID=""
case "${1:-}" in
  -v|--version) marathon_version; exit 0 ;;
  -r|--resume)
    RESUME_ID="${2:-}"
    if [[ -z "$RESUME_ID" ]]; then
      echo "error: --resume requires a session id" >&2
      exit 64
    fi
    shift 2
    ;;
esac

if [[ $# -lt 1 || -z "${1:-}" ]]; then
  cat >&2 <<'USAGE'
Usage: claude-marathon [--resume <session-id>] "<task description>" [workdir]

Runs Claude Code headless in a loop, sleeping through usage-limit resets and
resuming the same conversation until the task self-reports complete.

  --resume <id>   Resume a specific existing session on the first iteration
                  (instead of starting a fresh conversation). Find ids with
                  `claude --resume` or in ~/.claude/projects/.

Env overrides: MARATHON_MAX_ITERS, MARATHON_TIMEOUT, MARATHON_FALLBACK_SLEEP,
MARATHON_BUFFER, MARATHON_LOG_DIR, MARATHON_SENTINEL, MARATHON_NOTIFY.
USAGE
  exit 64
fi

if contains_smart_quotes "$*"; then
  echo "error: your task contains curly/smart quotes (“ ” ‘ ’), not straight quotes (\")." >&2
  echo "The shell split your task into words. Retype it with straight quotes." >&2
  exit 64
fi

WORKDIR=$(cd "${2:-$PWD}" && pwd)
if ! acquire_lock "$WORKDIR"; then
  echo "error: a marathon is already running for $WORKDIR." >&2
  echo "Stop it first, or target a different directory. (one marathon per directory)" >&2
  exit 65
fi
trap 'release_lock "$WORKDIR"' EXIT INT TERM

run_marathon "$1" "$WORKDIR" "$RESUME_ID"
