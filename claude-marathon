#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
# shellcheck source=marathon-lib.sh
source "$SCRIPT_DIR/marathon-lib.sh"

case "${1:-}" in
  -v|--version) marathon_version; exit 0 ;;
esac

if [[ $# -lt 1 || -z "${1:-}" ]]; then
  cat >&2 <<'USAGE'
Usage: claude-marathon "<task description>" [workdir]

Runs Claude Code headless in a loop, sleeping through usage-limit resets and
resuming the same conversation until the task self-reports complete.

Env overrides: MARATHON_MAX_ITERS, MARATHON_TIMEOUT, MARATHON_FALLBACK_SLEEP,
MARATHON_BUFFER, MARATHON_LOG_DIR, MARATHON_SENTINEL, MARATHON_NOTIFY.
USAGE
  exit 64
fi

run_marathon "$1" "${2:-$PWD}"
