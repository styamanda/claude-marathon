#!/usr/bin/env bash
set -uo pipefail
# Resolve symlinks so the lib + claude-marathon are found via a symlink on PATH.
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR=$(cd -P "$(dirname "$SOURCE")" && pwd)
  SOURCE=$(readlink "$SOURCE")
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR=$(cd -P "$(dirname "$SOURCE")" && pwd)
# shellcheck source=marathon-lib.sh
source "$SCRIPT_DIR/marathon-lib.sh"

show_usage() {
  cat <<'USAGE'
Usage:
  marathon-launchd --list
  marathon-launchd [--dry-run] [--resume <session-id>] "<task>" [workdir]
  marathon-launchd [--dry-run] --queue <file> [--stop-on-fail] [workdir]

Installs a macOS LaunchAgent that runs detached (survives logout), wrapped in
caffeinate so the Mac won't sleep. The job self-removes when finished, so it
will not re-run on reboot.

  -h, --help       Show this help
  -v, --version    Print version
  --list           List loaded claude-marathon LaunchAgents and stop commands.
  --dry-run        Write the plist and print the load command, but don't load it.
  --watch          After loading, open a Terminal window tailing the live log.
  --resume <id>    Resume a specific existing session on the first iteration.
  --queue <file>   Run multiple tasks from <file> (separated by lines of `---`),
                   each as its own fresh isolated session.
  --stop-on-fail   (queue mode) Halt on the first failing task.
USAGE
}

case "${1:-}" in
  -h|--help) show_usage; exit 0 ;;
  -v|--version) marathon_version; exit 0 ;;
  --list) marathon_launchd_jobs; exit $? ;;
esac

DRYRUN=0
RESUME_ID=""
QUEUE_FILE=""
STOP_ON_FAIL=""
WATCH=0
while [[ "${1:-}" == --* ]]; do
  case "$1" in
    --dry-run) DRYRUN=1; shift ;;
    --watch) WATCH=1; shift ;;
    --resume)
      RESUME_ID="${2:-}"
      [[ -z "$RESUME_ID" ]] && { echo "error: --resume requires a session id" >&2; exit 64; }
      shift 2 ;;
    --queue)
      QUEUE_FILE="${2:-}"
      [[ -z "$QUEUE_FILE" ]] && { echo "error: --queue requires a file path" >&2; exit 64; }
      shift 2 ;;
    --stop-on-fail) STOP_ON_FAIL=1; shift ;;
    *) break ;;
  esac
done

# Guard the #1 real-world failure: curly/smart quotes pasted from an editor.
# The shell never treated them as quotes, so the task got split across args
# (and the workdir consumed). Catch it here with a clear message rather than
# silently loading a broken job.
if contains_smart_quotes "$*"; then
  cat >&2 <<'SMARTQ'
error: your command contains curly/smart quotes (“ ” ‘ ’), not straight quotes.
The shell does not treat curly quotes as quoting, so your task got split into
words and the workdir was lost. Retype the command using straight quotes ("):

  marathon-launchd --resume <id> "Your task here" /path/to/repo

Tip: type the quotes directly in the terminal; don't paste them from a notes
app or editor that auto-converts " into “ ”.
SMARTQ
  exit 64
fi

LABEL="com.claude-marathon.$(date +%Y%m%d-%H%M%S)"
LA_DIR="$HOME/Library/LaunchAgents"
PLIST="$LA_DIR/$LABEL.plist"
LOGDIR="${MARATHON_LOG_DIR:-$HOME/.claude/marathon-logs}"
LOGFILE="$LOGDIR/$LABEL.log"

# Resolve claude to an absolute path now (interactive shell has it on PATH).
# launchd runs the job under a minimal PATH that omits ~/.local/bin, so the
# job must call claude by absolute path, not rely on PATH.
CLAUDE_BIN=$(command -v claude 2>/dev/null || true)
[[ -z "$CLAUDE_BIN" ]] && CLAUDE_BIN="claude"

mkdir -p "$LA_DIR" "$LOGDIR"

if [[ -n "$QUEUE_FILE" ]]; then
  # Queue mode: positional $1 = optional workdir (no task argument).
  if [[ ! -f "$QUEUE_FILE" ]]; then
    echo "error: queue file not found: $QUEUE_FILE" >&2
    exit 66
  fi
  QUEUE_FILE=$(cd "$(dirname "$QUEUE_FILE")" && pwd)/$(basename "$QUEUE_FILE")
  WORKDIR=$(cd "${1:-$PWD}" && pwd)
  SCRIPT="$SCRIPT_DIR/marathon-queue"
  render_launchd_queue_plist "$LABEL" "$QUEUE_FILE" "$WORKDIR" "$LOGFILE" "$SCRIPT" "$STOP_ON_FAIL" "$CLAUDE_BIN" > "$PLIST"
  DESC_KEY="queue:   $QUEUE_FILE"
else
  if [[ $# -lt 1 || -z "${1:-}" ]]; then
    show_usage >&2
    exit 64
  fi
  TASK="$1"
  WORKDIR=$(cd "${2:-$PWD}" && pwd)
  SCRIPT="$SCRIPT_DIR/claude-marathon"
  render_launchd_plist "$LABEL" "$TASK" "$WORKDIR" "$LOGFILE" "$SCRIPT" "$RESUME_ID" "$CLAUDE_BIN" > "$PLIST"
  DESC_KEY="task:    $TASK"
fi

if (( DRYRUN )); then
  echo "Wrote (dry-run): $PLIST"
  echo "Load with: launchctl bootstrap gui/$(id -u) \"$PLIST\""
  exit 0
fi

COLLIDE=$(detect_dir_collision "$WORKDIR")
if [[ -n "$COLLIDE" ]]; then
  rm -f "$PLIST"
  echo "error: another Claude session is already active in $WORKDIR (pid(s): $COLLIDE)." >&2
  echo "A marathon would share that conversation and collide. Close it first" >&2
  echo "(e.g. your VS Code / terminal Claude), or set MARATHON_ALLOW_SHARED_DIR=1 to override." >&2
  exit 65
fi

if lock_held "$WORKDIR"; then
  rm -f "$PLIST"
  echo "error: a marathon is already running for $WORKDIR." >&2
  echo "Stop it first:  claude-marathon --stop \"$WORKDIR\"   (or launchctl bootout gui/$(id -u)/<label>)" >&2
  echo "Or target a different directory. (one marathon per directory)" >&2
  exit 65
fi

launchctl bootstrap "gui/$(id -u)" "$PLIST"
echo "Loaded LaunchAgent: $LABEL"
echo "  $DESC_KEY"
echo "  workdir: $WORKDIR"
echo "  log:     $LOGFILE"
echo "  plist:   $PLIST (self-removes on completion)"
echo "Stop early with: claude-marathon --stop \"$WORKDIR\"   (or launchctl bootout gui/$(id -u)/$LABEL)"

# Warn if the Mac is likely to sleep mid-run. caffeinate keeps it awake while the
# lid is OPEN, but closing the lid (especially on battery) sleeps the Mac and
# pauses the run until you reopen it. It resumes cleanly on wake, but makes no
# progress while asleep — so for a true overnight run, stay plugged in, lid open.
if command -v pmset >/dev/null 2>&1 && pmset -g batt 2>/dev/null | grep -q 'Battery Power'; then
  echo "WARNING: you're on BATTERY. Keep the lid OPEN (and plug in) or macOS will sleep"
  echo "         and pause the run — it resumes when you reopen the laptop, but does NOT"
  echo "         work while asleep. Closing the lid is what stalled previous overnight runs."
fi

# Let the user know it actually started (a desktop ping), and optionally pop a
# live log terminal so they can watch it work.
notify "claude-marathon started" "$DESC_KEY"
if (( WATCH )); then
  if open_log_terminal "$LOGFILE"; then
    echo "  watching: opened a Terminal window tailing the log."
  else
    echo "  (--watch needs macOS Terminal; tail it yourself: tail -F \"$LOGFILE\")"
  fi
else
  echo "Watch it live:   tail -F \"$LOGFILE\"   (or re-run with --watch to auto-open a window)"
fi
